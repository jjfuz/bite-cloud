          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert Company in Job JSON" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

def body = prev.getResponseDataAsString()
def data = new JsonSlurper().parseText(body)
def expected = vars.get('expected_company_id')
if (data.company != expected) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage("Expected job company=" + expected + ", got=" + data.company)
}</stringProp>
